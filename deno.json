{
  "name": "@hdae/sbv2-web",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    ".": "./src/mod.ts",
    "./node": "./src/node/mod.ts"
  },
  "imports": {
    "@hdae/yomi": "jsr:@hdae/yomi@^0.2.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "onnxruntime-common": "npm:onnxruntime-common@1.27.0",
    "onnxruntime-web": "npm:onnxruntime-web@1.27.0",
    "onnxruntime-node": "npm:onnxruntime-node@1.27.0"
  },
  "tasks": {
    "check": "deno fmt --check .github CLAUDE.md README.md deno.json docs scripts src examples/cli tools/bench && deno lint src examples/cli tools/bench scripts && deno check src/mod.ts && deno test --allow-read",
    "check:node": "deno check src/node/mod.ts examples/cli/synthesize_node.ts",
    "bench:smoke": "deno run --allow-all tools/bench/smoke_one.ts",
    "bench:matrix": "deno run --allow-all tools/bench/run_matrix.ts",
    "cli": "deno run --allow-all examples/cli/synthesize_node.ts",
    "bump": "deno run --allow-read --allow-run=deno,git --allow-write=src/core.ts --no-lock scripts/bump.ts"
  },
  "fmt": {
    "proseWrap": "preserve"
  },
  "compilerOptions": {
    "lib": [
      "deno.window",
      "dom",
      "dom.iterable",
      "esnext"
    ]
  },
  "publish": {
    "include": [
      "README.md",
      "LICENSE",
      "deno.json",
      "src/**/*.ts",
      "docs/**/*.md"
    ],
    "exclude": [
      "src/**/*.test.ts",
      "src/testing/**"
    ]
  },
  "minimumDependencyAge":{
    "exclude": [
      "jsr:@hdae/yomi"
    ]
  }
}
