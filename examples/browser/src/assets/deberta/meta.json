{
  "source_repo": "tsukumijima/deberta-v2-large-japanese-char-wwm-onnx",
  "tokenizer_class": "BertJapaneseTokenizer",
  "vocab_size": 22012,
  "special_tokens": {
    "pad": {
      "token": "[PAD]",
      "id": 0
    },
    "cls": {
      "token": "[CLS]",
      "id": 1
    },
    "sep": {
      "token": "[SEP]",
      "id": 2
    },
    "unk": {
      "token": "[UNK]",
      "id": 3
    },
    "mask": {
      "token": "[MASK]",
      "id": 4
    }
  },
  "normalization": {
    "bert_clean_text": true,
    "handle_chinese_chars": false,
    "strip_accents": false,
    "lowercase": false,
    "nfkc": true
  },
  "subword_tokenizer_type": "character"
}
